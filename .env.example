# Copy this file to .env and configure one of the options below.
#
# Option 1 — Use Ollama (local, no API key or rate limits)
# USE_OLLAMA=true
# OLLAMA_MODEL=llama3.2
#
# Option 2 — Use Gemini (requires API key; free tier has rate limits)
# Get a free API key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your_key_here
#
# W&B (optional, for LEGR training)
# W&B_API_KEY=your_wandb_key
